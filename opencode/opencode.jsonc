{
  // see https://opencode.ai/docs/config
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "share": "disabled",
  "experimental": { "openTelemetry": false },

  "theme": "system",
  "formatter": false,
  "permission": "ask",
  "default_agent": "plan",
  "tui": { "diff_style": "stacked" },
}
