{
  // see https://opencode.ai/docs/config
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "share": "disabled",
  "experimental": { "openTelemetry": false },

  "formatter": false,
  "default_agent": "plan",

